# quantTrader simulated runtime defaults
#
# Copy this file to .env before running from quantFinance/docker-compose.yml:
#   cp ../quantTrader/.env.example ../quantTrader/.env
#
# Mongo connection is supplied by quantFinance/docker-compose.yml:
#   TRADER_MONGO_URI=${DOCKER_MONGO_URI:-mongodb://quant-mongodb:27017/}
#   TRADER_MONGO_DB=${MONGO_DB}

# Must be dev. The fake xtquant package refuses to load outside dev mode.
QUANT_TRADER_ENV=dev

# Insert or update a securities_accounts row at container startup so account
# and position sync can write linked records. Set to 0 only if you seed it
# yourself.
QUANT_TRADER_SEED_SIM_ACCOUNT=1

# Broker name used only when the startup seed creates a brand-new securities
# account. Existing development account records keep their original broker and
# account_id so the simulator does not disguise a real dev account.
QUANT_TRADER_SIM_BROKER_NAME=SIMULATED_MINIQMT

# Advance the fake miniQMT matching engine whenever quantTrader queries order
# status. Keep this enabled for Docker runtime so submitted simulation orders
# can become filled without test code calling engine.tick().
QUANT_TRADER_SIM_AUTO_TICK=1

# Restore simulated cash, positions, and next qmt_order_id from Mongo snapshots
# at startup so a container restart does not reset the fake miniQMT account.
# This does not restore in-flight submitted orders; avoid restarting with live
# submitted simulation orders until quant_trader_sim_states is added.
QUANT_TRADER_SIM_RESTORE_STATE=1

# DB mode talks directly to MongoDB. This is the recommended Docker simulation
# mode because it exercises the same database path used by quantFinance.
TRADER_BACKEND_MODE=db

# User and securities account identifiers used to read signals and write trader
# state. Replace these with existing development-system IDs when you want the
# simulator to attach to a real dev account record.
TRADER_USER_ID=sim-e2e-user
TRADER_SECURITIES_ACCOUNT_ID=00000000000000000000e2e1

# Keep miniQMT here so the real MiniQMTBroker adapter is exercised. Docker uses
# fake xtquant from PYTHONPATH, not a real Windows miniQMT installation.
TRADER_BROKER=miniQMT
TRADER_MINIQMT_XT_PATH=/tmp/fake-userdata-mini

# miniQMT account_id. In simulation this identifies the fake trading account;
# for dev integration you can set it to the account_id on securities_accounts.
TRADER_MINIQMT_ACCOUNT_ID=SIM-ACC-0001

# Main loop interval and log verbosity.
TRADER_POLL_INTERVAL=1.0
TRADER_LOG_LEVEL=INFO

# Trading session gate. For miniQMT the code defaults to CN_A when this variable
# is not set. Set it to an empty value to let dev/CI simulation process signals
# at any wall-clock time. Example real-session override: 09:30-11:30,13:00-15:00.
QUANT_TRADER_TRADING_SESSIONS=

# Whether to honor signal.activate_after. Keep false for dev simulation so a
# signal generated with a future activation time is processed immediately.
QUANT_TRADER_USE_ACTIVATE_AFTER=false

# Optional API mode example. Leave commented for Docker simulation.
# TRADER_BACKEND_MODE=api
# TRADER_API_BASE_URL=http://localhost:8000/api
# TRADER_API_TOKEN=your_access_token_here
